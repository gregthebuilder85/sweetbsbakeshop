# Sweet B's HQ — environment variables
# Copy to .env.local (Vite) / set in Supabase for functions. Never commit .env.

# --- Frontend (Vite: must be prefixed VITE_) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Edge functions (set via `supabase secrets set`) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
ANTHROPIC_API_KEY=sk-ant-xxx
RESEND_API_KEY=re_xxx
FROM_EMAIL=Annalise <hello@sweetbsbakeshop.com>
SITE_URL=https://sweetbsbakeshop.com
